{
  "name": "rust-pattern-viz",
  "displayName": "Rust Pattern Visualizer",
  "description": "Visualize Rust pattern matching, control flow, and decision trees directly in VS Code",
  "version": "1.0.0",
  "publisher": "your-publisher-name",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/rust-pattern-viz"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "Education"
  ],
  "keywords": [
    "rust",
    "pattern matching",
    "visualization",
    "code analysis",
    "control flow"
  ],
  "activationEvents": [
    "onLanguage:rust",
    "onView:rustPatternViz"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rust-pattern-viz",
          "title": "Rust Patterns",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "rust-pattern-viz": [
        {
          "type": "webview",
          "id": "rustPatternViz.view",
          "name": "Pattern Visualization"
        }
      ]
    },
    "commands": [
      {
        "command": "rustPatternViz.refresh",
        "title": "Refresh Pattern Analysis",
        "icon": "$(refresh)"
      },
      {
        "command": "rustPatternViz.exportSvg",
        "title": "Export SVG Diagram",
        "icon": "$(export)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "rustPatternViz.refresh",
          "when": "view == rustPatternViz.view",
          "group": "navigation"
        },
        {
          "command": "rustPatternViz.exportSvg",
          "when": "view == rustPatternViz.view",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Rust Pattern Visualizer",
      "properties": {
        "rustPatternViz.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh visualization when file changes"
        },
        "rustPatternViz.debounceDelay": {
          "type": "number",
          "default": 500,
          "description": "Delay (ms) before auto-refresh triggers after typing"
        },
        "rustPatternViz.showConfidenceScores": {
          "type": "boolean",
          "default": true,
          "description": "Display confidence scores in visualizations"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:wasm && npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "build:wasm": "cd .. && wasm-pack build --target web --out-dir vscode-extension/wasm",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^8.0.0",
    "ts-loader": "^9.4.0",
    "typescript": "^5.0.0",
    "webpack": "^5.80.0",
    "webpack-cli": "^5.0.0"
  },
  "dependencies": {}
}
