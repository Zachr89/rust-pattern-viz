{
  "name": "rust-pattern-viz",
  "displayName": "Rust Pattern Visualizer",
  "description": "Generate interactive pattern diagrams on hover - visualize error handling, iterators, and control flow",
  "version": "0.1.0",
  "publisher": "rust-pattern-viz",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "rust",
    "visualization",
    "patterns",
    "diagrams",
    "analysis"
  ],
  "activationEvents": [
    "onLanguage:rust"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Rust Pattern Visualizer",
      "properties": {
        "rustPatternViz.cliPath": {
          "type": "string",
          "default": "",
          "description": "Path to rpv CLI tool (leave empty for auto-detect)"
        },
        "rustPatternViz.enableHover": {
          "type": "boolean",
          "default": true,
          "description": "Enable hover diagrams (Pro feature preview)"
        },
        "rustPatternViz.maxDiagramSize": {
          "type": "number",
          "default": 5000,
          "description": "Maximum diagram height in pixels"
        }
      }
    },
    "commands": [
      {
        "command": "rustPatternViz.generateDiagram",
        "title": "Rust Pattern Viz: Generate Diagram for Current File"
      },
      {
        "command": "rustPatternViz.openSettings",
        "title": "Rust Pattern Viz: Open Settings"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/test-electron": "^2.3.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.22.0"
  },
  "dependencies": {},
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/rust-pattern-viz"
  },
  "bugs": {
    "url": "https://github.com/yourusername/rust-pattern-viz/issues"
  },
  "license": "MIT",
  "preview": true,
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "badges": [
    {
      "url": "https://img.shields.io/badge/status-beta-yellow",
      "href": "https://github.com/yourusername/rust-pattern-viz",
      "description": "Beta Release"
    }
  ]
}
